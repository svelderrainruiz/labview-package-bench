# VIPM Pro activation credentials for the docker-windows build container.
#
# Copy this file to `.env` (which is gitignored) and fill in your values. Find
# your serial number on https://www.vipm.io/account/. Activating VIPM Pro is
# required to build VI packages inside a container today.
#
# The docker-windows provider forwards these variables into the container by
# name only (docker run -e VIPM_SERIAL_NUMBER ...), so set them in the
# environment VS Code runs in. For manual/compose builds, pass this file with
# `docker run --env-file docker/windows/.env ...`.
VIPM_SERIAL_NUMBER=your-serial-number-here
VIPM_FULL_NAME=Your Full Name
VIPM_EMAIL=your.email@example.com
